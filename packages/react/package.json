{
  "name": "@oauth-spa-kit/react",
  "version": "0.1.0",
  "description": "React bindings for @oauth-spa-kit/core's session client -- an AuthProvider + useAuth() hook, same shape as nuxt-auth-utils' useUserSession composable.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@oauth-spa-kit/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.6.0"
  }
}
