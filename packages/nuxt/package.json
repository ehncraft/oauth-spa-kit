{
  "name": "@oauth-spa-kit/nuxt",
  "version": "1.2.0",
  "description": "Nuxt module wiring @oauth-spa-kit/server's handlers as Nitro server routes, plus a useAuth() composable over @oauth-spa-kit/core's session client.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ehncraft/oauth-spa-kit.git",
    "directory": "packages/nuxt"
  },
  "type": "module",
  "main": "./dist/module.mjs",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "nuxt-module-build build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground"
  },
  "dependencies": {
    "@oauth-spa-kit/core": "workspace:*",
    "@oauth-spa-kit/server": "workspace:*",
    "@nuxt/kit": "^3.14.0",
    "defu": "^6.1.0",
    "h3": "^1.13.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.0",
    "@nuxt/schema": "^3.14.0",
    "nuxt": "^3.14.0",
    "vue": "^3.5.0",
    "typescript": "^5.6.0"
  }
}
